#include <iostream>
#include <string>
#include <iomanip>
using namespace std;
 
struct Product {
    int    id;
    string name;
    string category;
    int    quantity;
    float  price;
};
 
struct Node {
    Product data;
    Node*   next;
};
 
struct StackNode {
    Product    data;
    StackNode* next;
};
 
class LinkedList {
private:
    Node* head;
    int   count;
 
public:
    LinkedList() : head(NULL), count(0) {}
 
    void addProduct(Product p) {
        Node* newNode = new Node();
        newNode->data = p;
        newNode->next = NULL;
 
        if (head == NULL) {
            head = newNode;
        } else {
            Node* temp = head;
            while (temp->next != NULL)
                temp = temp->next;
            temp->next = newNode;
        }
        count++;
        cout << "\n  [OK] Product added successfully!\n";
    }
 
    void displayAll() {
        if (head == NULL) {
            cout << "\n  [!] No products in inventory.\n";
            return;
        }
        cout << "\n";
        cout << "  " << string(72, '-') << "\n";
        cout << "  " << left
             << setw(6)  << "ID"
             << setw(18) << "Name"
             << setw(14) << "Category"
             << setw(10) << "Qty"
             << setw(10) << "Price(Rs)"
             << "\n";
        cout << "  " << string(72, '-') << "\n";
 
        Node* temp = head;
        while (temp != NULL) {
            cout << "  "
                 << setw(6)  << temp->data.id
                 << setw(18) << temp->data.name
                 << setw(14) << temp->data.category
                 << setw(10) << temp->data.quantity
                 << setw(10) << fixed << setprecision(2) << temp->data.price
                 << "\n";
            temp = temp->next;
        }
        cout << "  " << string(72, '-') << "\n";
        cout << "  Total Products: " << count << "\n";
    }
 
    bool updateProduct(int id) {
        Node* temp = head;
        while (temp != NULL) {
            if (temp->data.id == id) {
                cout << "\n  Current Name     : " << temp->data.name;
                cout << "\n  Current Category : " << temp->data.category;
                cout << "\n  Current Quantity : " << temp->data.quantity;
                cout << "\n  Current Price    : " << temp->data.price;
                cout << "\n\n  Enter new Name     : "; cin.ignore(); getline(cin, temp->data.name);
                cout << "  Enter new Category : "; getline(cin, temp->data.category);
                cout << "  Enter new Quantity : "; cin >> temp->data.quantity;
                cout << "  Enter new Price    : "; cin >> temp->data.price;
                cout << "\n  [OK] Product updated successfully!\n";
                return true;
            }
            temp = temp->next;
        }
        return false;
    }
 
    bool deleteProduct(int id, Product& deleted) {
        if (head == NULL) return false;
 
        if (head->data.id == id) {
            deleted = head->data;
            Node* temp = head;
            head = head->next;
            delete temp;
            count--;
            return true;
        }
 
        Node* prev = head;
        Node* curr = head->next;
        while (curr != NULL) {
            if (curr->data.id == id) {
                deleted = curr->data;
                prev->next = curr->next;
                delete curr;
                count--;
                return true;
            }
            prev = curr;
            curr = curr->next;
        }
        return false;
    }
 
    void checkLowStock(int threshold = 5) {
        cout << "\n  [Low Stock Report — Qty < " << threshold << "]\n";
        cout << "  " << string(50, '-') << "\n";
        bool found = false;
        Node* temp = head;
        while (temp != NULL) {
            if (temp->data.quantity < threshold) {
                cout << "  ID: " << temp->data.id
                     << "  |  " << temp->data.name
                     << "  |  Qty: " << temp->data.quantity << "\n";
                found = true;
            }
            temp = temp->next;
        }
        if (!found)
            cout << "  All products have sufficient stock.\n";
        cout << "  " << string(50, '-') << "\n";
    }
 
    Node* getHead() { return head; }
 
    int nextID() {
        int maxID = 0;
        Node* temp = head;
        while (temp != NULL) {
            if (temp->data.id > maxID) maxID = temp->data.id;
            temp = temp->next;
        }
        return maxID + 1;
    }
 
    ~LinkedList() {
        Node* temp;
        while (head != NULL) {
            temp = head;
            head = head->next;
            delete temp;
        }
    }
};
